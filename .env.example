# TCC PoC - Environment Variables
# Copy this file to .env and fill in your values

# Azure Subscription
SUBSCRIPTION_ID=<your-subscription-id>

# Elasticsearch (on-prem / simulated VM)
ELASTICSEARCH_URL=http://<elasticsearch-vm-ip>:9200
ELASTICSEARCH_INDEX=infrastructure-logs

# Azure AI Search
AI_SEARCH_ENDPOINT=https://search-tcc-poc.search.windows.net
AI_SEARCH_KEY=<your-ai-search-admin-key>
AI_SEARCH_INDEX=logs-index

# Azure OpenAI / AI Foundry
# NOTE: Subscription policy enforces disableLocalAuth=true on Cognitive Services.
# All code uses DefaultAzureCredential (managed identity on VM, az login locally).
# AZURE_OPENAI_KEY can be left empty.
AZURE_OPENAI_ENDPOINT=https://ai-tcc-poc.openai.azure.com/
AZURE_OPENAI_KEY=
AZURE_OPENAI_CHAT_DEPLOYMENT=gpt-4o
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-ada-002

# MCP Server
MCP_SERVER_HOST=0.0.0.0
MCP_SERVER_PORT=8080
MCP_SERVER_URL=http://localhost:8080

# Sync settings
SYNC_INTERVAL_SECONDS=30
BATCH_SIZE=100
